---
import ProgressRail from '../components/scroll/ProgressRail.tsx';
import { PARTS, partBySlug } from '../lib/parts';
import { partAccent } from '../lib/encoding';
import BaseLayout from './BaseLayout.astro';

interface Props {
  slug: string;
  title: string;
}

const { slug, title } = Astro.props;
const part = partBySlug(slug);
const index = part?.index ?? 0;
const accent = partAccent(part?.kind ?? 'neutral');
const prev = PARTS[index - 1];
const next = PARTS[index + 1];
---

<BaseLayout title={`${title} · Descent`}>
  <ProgressRail client:idle parts={[...PARTS]} currentSlug={slug} />

  <main class="px-6 pb-40 pt-24 md:pl-24">
    <div class="mx-auto max-w-5xl">
      <header class="mx-auto max-w-prose">
        <div class="flex items-center gap-3 font-mono text-sm">
          <span
            class="inline-flex h-7 w-7 items-center justify-center rounded-full border"
            style={`border-color:${accent};color:${accent}`}
          >
            {index}
          </span>
          <span class="uppercase tracking-widest text-muted">Descent · part {index}</span>
        </div>
        {
          part && (
            <p class="mt-4 text-lg italic text-muted">
              {part.question}
            </p>
          )
        }
      </header>

      <div class="descent-prose mt-8">
        <slot />
      </div>

      <nav
        class="mx-auto mt-24 flex max-w-prose items-center justify-between gap-4 border-t border-border pt-8 text-sm"
        aria-label="Descent navigation"
      >
        {
          prev ? (
            <a class="group text-muted hover:text-ink" href={`/parts/${prev.slug}`}>
              <span class="block text-xs uppercase tracking-widest opacity-60">↑ ascend</span>
              <span class="font-medium">{prev.title}</span>
            </a>
          ) : (
            <a class="group text-muted hover:text-ink" href="/">
              <span class="block text-xs uppercase tracking-widest opacity-60">↑ ascend</span>
              <span class="font-medium">Top of the descent</span>
            </a>
          )
        }
        {
          next ? (
            <a class="group text-right text-muted hover:text-ink" href={`/parts/${next.slug}`}>
              <span class="block text-xs uppercase tracking-widest opacity-60">descend ↓</span>
              <span class="font-medium">{next.title}</span>
            </a>
          ) : (
            <a class="group text-right text-muted hover:text-ink" href="/">
              <span class="block text-xs uppercase tracking-widest opacity-60">descend ↓</span>
              <span class="font-medium">Back to the top</span>
            </a>
          )
        }
      </nav>
    </div>
  </main>
</BaseLayout>

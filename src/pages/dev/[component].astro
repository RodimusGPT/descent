---
import TokenDemo from '../../components/dev/TokenDemo.tsx';
import AttentionFan from '../../components/viz/AttentionFan.tsx';
import Autoregression from '../../components/viz/Autoregression.tsx';
import BlockScaling from '../../components/viz/BlockScaling.tsx';
import Distillation from '../../components/viz/Distillation.tsx';
import EmbeddingSpace from '../../components/viz/EmbeddingSpace.tsx';
import FloatExploder from '../../components/viz/FloatExploder.tsx';
import MemoryBudget from '../../components/viz/MemoryBudget.tsx';
import MoERouter from '../../components/viz/MoERouter.tsx';
import PrefillDecode from '../../components/viz/PrefillDecode.tsx';
import QKVMultiHead from '../../components/viz/QKVMultiHead.tsx';
import QuantizationSlider from '../../components/viz/QuantizationSlider.tsx';
import SamplingPlayground from '../../components/viz/SamplingPlayground.tsx';
import Tokenizer from '../../components/viz/Tokenizer.tsx';
import TransformerStack from '../../components/viz/TransformerStack.tsx';
import ZoomToWeight from '../../components/viz/ZoomToWeight.tsx';
import { DEV_SANDBOXES } from '../../lib/dev-registry';
import BaseLayout from '../../layouts/BaseLayout.astro';

// getStaticPaths runs in an isolated scope and may only reference imports, so it
// derives the routes from DEV_SANDBOXES (imported). Each slug is wired to its island
// by an explicit conditional below — Astro requires a static reference per island to
// generate its hydration script, so a dynamic <Comp/> will not work.
export function getStaticPaths() {
  return DEV_SANDBOXES.map((s) => ({ params: { component: s.slug } }));
}

const { component } = Astro.params;
const meta = DEV_SANDBOXES.find((s) => s.slug === component);
---

<BaseLayout title={`dev · ${meta?.title ?? component}`}>
  <main class="mx-auto max-w-4xl px-6 py-12">
    <a class="text-sm text-muted hover:text-ink" href="/dev">← all sandboxes</a>
    <h1 class="mt-2 text-2xl font-bold text-ink">{meta?.title}</h1>
    <p class="text-sm text-muted">{meta?.description}</p>
    <div class="mt-8 rounded-xl border border-border bg-surface/40 p-6">
      {component === 'token' && <TokenDemo client:load />}
      {component === 'attention' && <AttentionFan client:load />}
      {component === 'float' && <FloatExploder client:load />}
      {component === 'quant' && <QuantizationSlider client:load />}
      {component === 'prefill' && <PrefillDecode client:load />}
      {component === 'tokenizer' && <Tokenizer client:load />}
      {component === 'embeddings' && <EmbeddingSpace client:load />}
      {component === 'stack' && <TransformerStack client:load />}
      {component === 'qkv' && <QKVMultiHead client:load />}
      {component === 'moe' && <MoERouter client:load />}
      {component === 'sampling' && <SamplingPlayground client:load />}
      {component === 'autoregression' && <Autoregression client:load />}
      {component === 'zoom' && <ZoomToWeight client:load />}
      {component === 'budget' && <MemoryBudget client:load />}
      {component === 'blockscale' && <BlockScaling client:load />}
      {component === 'distill' && <Distillation client:load />}
    </div>
  </main>
</BaseLayout>

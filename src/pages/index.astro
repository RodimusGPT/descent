---
import { partAccent } from '../lib/encoding';
import { PARTS } from '../lib/parts';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Descent · How LLM inference works">
  <main class="mx-auto max-w-3xl px-6 pb-32">
    <!-- Hero / hook -->
    <section class="flex min-h-[80vh] flex-col justify-center">
      <p class="font-mono text-sm uppercase tracking-[0.3em] text-muted">A visual descent</p>
      <h1 class="mt-4 text-5xl font-bold tracking-tight text-ink sm:text-6xl">
        How an LLM<br />
        <span class="text-active">answers you</span>
      </h1>
      <p class="mt-6 max-w-prose text-lg leading-relaxed text-muted">
        You type a prompt and hit enter. What follows is a fall — from an abstract idea of a
        model, down through the numbers it is made of, down through the software that serves it,
        all the way to electrons moving through silicon. This is that descent, one token at a
        time.
      </p>
      <div class="mt-10 flex items-center gap-2 text-sm text-muted">
        <span aria-hidden="true" class="animate-pulse">↓</span>
        <span>scroll, or jump to any depth</span>
      </div>
    </section>

    <!-- The descent: table of contents that IS the journey -->
    <section aria-label="The six parts of the descent" class="relative pb-16">
      <ol class="relative space-y-3 border-l border-border pl-8">
        {
          PARTS.map((part) => {
            const accent = partAccent(part.kind);
            return (
              <li class="relative">
                <span
                  class="absolute -left-[2.35rem] top-3 block h-3 w-3 rounded-full border"
                  style={`background-color:${accent};border-color:${accent}`}
                  aria-hidden="true"
                />
                <a
                  href={`/parts/${part.slug}`}
                  class="group block rounded-lg border border-border bg-surface/40 p-5 transition-colors hover:border-active hover:bg-surface"
                >
                  <div class="flex items-baseline justify-between gap-4">
                    <h2 class="text-lg font-semibold text-ink">
                      <span class="font-mono text-sm text-muted">{part.index} · </span>
                      {part.title}
                    </h2>
                    <span
                      class="font-mono text-xs uppercase tracking-widest opacity-70"
                      style={`color:${accent}`}
                    >
                      {part.depth}
                    </span>
                  </div>
                  <p class="mt-1 text-sm italic text-muted">{part.question}</p>
                </a>
              </li>
            );
          })
        }
      </ol>
    </section>

    <footer class="mt-12 border-t border-border pt-8 text-sm text-muted">
      <p>
        Built as a single continuous explainer. Each part is anchored by an interactive you can
        poke at. Reduced-motion and keyboard navigation are supported throughout.
      </p>
    </footer>
  </main>
</BaseLayout>
